rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Las pruebas de nomina de Cata usan exclusivamente cuentas de Google.
    function googleUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    // Correo normalizado (minusculas) del usuario autenticado.
    function userEmail() {
      return request.auth.token.email.lower();
    }

    // Administradores: ven todo, configuran horarios y corrigen registros.
    function isAdmin() {
      return signedIn() && userEmail() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com'
      ];
    }

    // Equipo autorizado (lista blanca). Mantener sincronizado con HUB.USERS en app.js.
    function isTeam() {
      return signedIn() && userEmail() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com',
        'angiecamilar4@gmail.com',
        'licethrinconr@gmail.com'
      ];
    }

    // Un usuario autenticado escribe solo su propio registro de jornada por el flujo normal.
    // La app ya bloquea el acceso a correos fuera de HUB.USERS; aqui evitamos duplicar
    // la lista para que QR/remoto no falle cuando el equipo cambia.
    function writesOwnRecord() {
      return signedIn()
        && request.resource.data.email == userEmail()
        && request.resource.data.role == 'administrativo';
    }

    function readsOwnResource() {
      return signedIn() && resource.data.email == userEmail();
    }

    // ===== Manager Musicala =====
    function managerUserDocPath() {
      return /databases/$(database)/documents/apps/manager-musicala/users/$(request.auth.uid);
    }

    function managerHasUserDoc() {
      return signedIn() && exists(managerUserDocPath());
    }

    function managerUserDoc() {
      return get(managerUserDocPath()).data;
    }

    function isManagerBootstrapAdmin() {
      return signedIn() && userEmail() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com'
      ];
    }

    // Invitacion de asistente por correo: el id del documento es el correo
    // (en minusculas). Cada persona puede leer la suya y, si esta activa,
    // entra directo como asistente.
    function managerAssistantInvitePath() {
      return /databases/$(database)/documents/apps/manager-musicala/assistantInvites/$(userEmail());
    }

    function managerHasActiveInvite() {
      return signedIn()
        && exists(managerAssistantInvitePath())
        && get(managerAssistantInvitePath()).data.active == true;
    }

    function isManagerActiveAdmin() {
      return signedIn() && (
        isManagerBootstrapAdmin() ||
        (
          managerHasUserDoc()
          && managerUserDoc().active == true
          && managerUserDoc().role == 'admin'
        )
      );
    }

    function isManagerActiveUser() {
      return signedIn() && (
        isManagerBootstrapAdmin() ||
        managerHasActiveInvite() ||
        (
          managerHasUserDoc()
          && managerUserDoc().active == true
        )
      );
    }

    function isManagerCertificateManager() {
      return signedIn() && (
        isManagerBootstrapAdmin() ||
        managerHasActiveInvite() ||
        (
          managerHasUserDoc()
          && managerUserDoc().active == true
          && managerUserDoc().role in ['admin', 'asistente']
        )
      );
    }

    function managerValidSelfCreate(userId) {
      return signedIn()
        && userId == request.auth.uid
        && request.resource.data.email == userEmail()
        && (
          (
            isManagerBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.active == true
          ) || (
            !isManagerBootstrapAdmin()
            && managerHasActiveInvite()
            && request.resource.data.role == 'asistente'
            && request.resource.data.active == true
          ) || (
            !isManagerBootstrapAdmin()
            && !managerHasActiveInvite()
            && request.resource.data.role in ['docente', 'asistente']
            && request.resource.data.active == false
          )
        );
    }

    // ===== Registros de jornada =====
    match /adminShiftRecords/{recordId} {
      // Crear/actualizar el propio registro (flujo normal: QR / remoto),
      // o cualquier registro si eres admin (correcciones y excepciones).
      allow create, update: if writesOwnRecord() || isAdmin();
      // Leer: el dueño ve lo suyo; el admin ve todo.
      allow read: if isAdmin() || readsOwnResource();
      // Nunca se borra: se usa el estado "voided".
      allow delete: if false;
    }

    // ===== Configuracion de horarios por miembro =====
    match /adminMemberSettings/{memberId} {
      // El miembro puede leer su propia configuracion; el admin lee todo.
      allow read: if isAdmin() || readsOwnResource();
      // Solo admins crean/editan horarios del equipo.
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ===== Excepciones de horario por fecha =====
    match /adminScheduleOverrides/{overrideId} {
      allow read: if isAdmin() || readsOwnResource();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ===== Datos aislados de Manager Musicala =====
    match /apps/manager-musicala {
      allow read, write: if false;

      match /users/{userId} {
        allow get: if signedIn() && (userId == request.auth.uid || isManagerActiveAdmin());
        allow list: if isManagerActiveAdmin();
        allow create: if managerValidSelfCreate(userId) || isManagerActiveAdmin();
        allow update: if isManagerActiveAdmin() || (
          signedIn()
          && userId == request.auth.uid
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt', 'lastLoginAt'])
            || (
              managerHasActiveInvite()
              && request.resource.data.role == 'asistente'
              && request.resource.data.active == true
            )
          )
        );
        allow delete: if isManagerActiveAdmin();
      }

      match /buttons/{buttonId} {
        allow read: if isManagerActiveUser();
        allow create, update, delete: if isManagerActiveAdmin();
      }

      match /schedule/{taskId} {
        allow read: if isManagerActiveUser();
        allow create, update, delete: if isManagerActiveAdmin();
      }

      match /legacyUsers/{legacyId} {
        allow read, write, delete: if isManagerActiveAdmin();
      }

      match /userInvites/{inviteId} {
        allow read, write, delete: if isManagerActiveAdmin();
      }

      match /imports/{importId} {
        allow read, write, delete: if isManagerActiveAdmin();
      }

      match /managerSettings/{settingId} {
        allow read: if isManagerActiveUser();
        allow write, delete: if isManagerActiveAdmin();
      }

      match /taskTemplates/{templateId} {
        allow read: if isManagerActiveAdmin();
        allow write, delete: if isManagerActiveAdmin();
      }

      match /certificates/{certificateId} {
        allow read: if isManagerActiveUser();
        allow create, update, delete: if isManagerCertificateManager();
      }

      // Novedades de nomina: cualquier cuenta Google puede crear y consultar.
      // Una novedad creada solo puede cambiar de estado y registrar quien/cuando
      // hizo el cambio; no se permite borrar el historial.
      match /novedades_nomina/{docId} {
        allow create, read: if googleUser();
        allow update: if googleUser()
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['estado', 'actualizadoPor', 'actualizadoEn']);
        allow delete: if false;
      }

      // Directorio de empleados usado por el flujo de nomina de Cata.
      match /empleados/{docId} {
        allow create, read, update: if googleUser();
        allow delete: if false;
      }

      // Notas personales del equipo. Cada usuario gestiona las suyas; los
      // administradores ven y auditan todas. Nunca se eliminan físicamente.
      match /workNotes/{noteId} {
        allow create: if isManagerActiveUser()
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.deleted == false;
        allow read: if isManagerActiveAdmin()
          || (isManagerActiveUser() && resource.data.ownerUid == request.auth.uid);
        allow update: if isManagerActiveAdmin() || (
          isManagerActiveUser()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.ownerEmail == resource.data.ownerEmail
        );
        allow delete: if false;
      }

      match /workNotePreferences/{userId} {
        allow read, create, update: if isManagerActiveAdmin()
          || (isManagerActiveUser() && userId == request.auth.uid);
        allow delete: if false;
      }

      // Directorio de asistentes por correo (id del doc = correo en minusculas).
      // Cada persona puede leer su propia invitacion para entrar directo.
      match /assistantInvites/{inviteEmail} {
        allow get: if isManagerActiveAdmin() || (signedIn() && inviteEmail == userEmail());
        allow list: if isManagerActiveAdmin();
        allow create, update, delete: if isManagerActiveAdmin();
      }

      // Candados (MusiLockers): todo el equipo activo ve; admin y asistentes gestionan.
      match /lockers/{lockerId} {
        allow read: if isManagerActiveUser();
        allow create, update, delete: if isManagerCertificateManager();
      }

      // Parqueadero (motos y ciclas): todo el equipo activo ve; admin y asistentes gestionan.
      match /parking/{spotId} {
        allow read: if isManagerActiveUser();
        allow create, update, delete: if isManagerCertificateManager();
      }
    }

    // Todo lo demas, denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
